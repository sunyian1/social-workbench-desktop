{
  "name": "social-workbench-desktop",
  "version": "0.1.0",
  "description": "Electron 多账号社媒工作台 MVP：Telegram / Instagram / Facebook / WhatsApp，多账号隔离、独立代理、基础指纹注入。",
  "main": "dist/main/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "npm-run-all -p dev electron:watch",
    "electron:watch": "wait-on tcp:5173 && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "rebuild:native": "electron-builder install-app-deps",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run typecheck && vite build && npm run build:main",
    "start": "electron .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@chakra-ui/react": "^2.10.9",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^11.8.1",
    "electron-log": "^5.2.4",
    "framer-motion": "^12.4.7",
    "nanoid": "^5.0.9",
    "proxy-chain": "^2.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.1",
    "vitest": "^3.0.5",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.jy.socialworkbench",
    "productName": "Social Workbench",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "package.json"],
    "win": { "target": "nsis" }
  }
}
